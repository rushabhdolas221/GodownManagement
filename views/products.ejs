<%- include('partials/header') %>

<h2 class="mb-4 fw-bold">Product Management</h2>

<!-- SEARCH BAR -->
<form method="GET" action="/products" class="mb-4">
  <div class="input-group">
    <input type="text" name="search" class="form-control" placeholder="Search product by name...">
    <button class="btn btn-dark">Search</button>
  </div>
</form>

<!-- ADD PRODUCT CARD -->
<div class="card shadow p-4 mb-4">
  <h5 class="mb-3">Add New Product</h5>
  <form action="/add-product" method="POST" class="row g-3">

    <div class="col-md-3">
      <input type="text" name="name" class="form-control" placeholder="Product Name" required>
    </div>

    <div class="col-md-2">
      <input type="text" name="category" class="form-control" placeholder="Category">
    </div>

    <div class="col-md-2">
      <input type="number" name="price" class="form-control" placeholder="Price">
    </div>

    <div class="col-md-2">
      <input type="number" name="reorderLevel" class="form-control" placeholder="Reorder Level">
    </div>

    <div class="col-md-2">
      <button class="btn btn-success w-100">Add Product</button>
    </div>

  </form>
</div>

<!-- PRODUCT TABLE -->
<div class="card shadow p-3">
  <table class="table table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Category</th>
        <th>Quantity</th>
        <th>Stock In</th>
        <th>Stock Out</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% if(products.length === 0) { %>
        <tr>
          <td colspan="6" class="text-center text-muted">No products found.</td>
        </tr>
      <% } %>

      <% products.forEach(p => { %>
        <tr>
          <td><strong><%= p.name %></strong></td>

          <td><%= p.category %></td>

          <!-- LOW STOCK HIGHLIGHT -->
          <td>
            <% if(p.quantity < p.reorderLevel) { %>
              <span class="badge bg-danger"><%= p.quantity %></span>
            <% } else { %>
              <span class="badge bg-success"><%= p.quantity %></span>
            <% } %>
          </td>

          <!-- STOCK IN -->
          <td>
            <form action="/stock-in/<%= p._id %>" method="POST" class="d-flex">
              <input type="number" name="quantity" class="form-control form-control-sm me-2" required>
              <button class="btn btn-success btn-sm">+</button>
            </form>
          </td>

          <!-- STOCK OUT -->
          <td>
            <form action="/stock-out/<%= p._id %>" method="POST" class="d-flex">
              <input type="number" name="quantity" class="form-control form-control-sm me-2" required>
              <button class="btn btn-danger btn-sm">-</button>
            </form>
          </td>

          <!-- ACTION BUTTONS -->
          <td>
            <a href="/edit-product/<%= p._id %>" class="btn btn-warning btn-sm me-2">
              Edit
            </a>

            <form action="/delete-product/<%= p._id %>" method="POST" style="display:inline;">
              <button class="btn btn-danger btn-sm"
                onclick="return confirm('Are you sure you want to delete this product?')">
                Delete
              </button>
            </form>
          </td>

        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/footer') %>